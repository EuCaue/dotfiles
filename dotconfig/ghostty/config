config-file=?auto/theme.ghostty
alpha-blending=linear
# adjust-box-thickness=100%
adjust-cursor-thickness=700%
# adjust-cell-height=35% 
# adjust-cell-height = -12%
adjust-cell-width = -10%
bell-features=border
#bold-is-bright=true
freetype-load-flags=no-hinting
clipboard-paste-bracketed-safe=true
custom-shader-animation=true
# custom-shader=./shaders/cursor_smear_fade.glsl
custom-shader=./shaders/cursor_warp.glsl
background-opacity=1
background-image-fit=cover
background-image-opacity=0.1
clipboard-paste-protection=true
clipboard-trim-trailing-spaces=true
confirm-close-surface=false
cursor-style=block
cursor-style-blink=true
# cursor-opacity=0.9
shell-integration-features=no-cursor,sudo,title
desktop-notifications=true
font-size=18.3
# font-family=JetBrainsMono Nerd Font
# font-family=monospace
font-family=monospace
font-family=Symbols Nerd Font
gtk-wide-tabs=true
gtk-titlebar-style=tabs
keybind=alt+eight=unbind
keybind=alt+five=unbind
keybind=alt+four=unbind
keybind=alt+nine=unbind
keybind=alt+one=unbind
keybind=alt+seven=unbind
keybind=alt+six=unbind
keybind=alt+three=unbind
keybind=alt+two=unbind
keybind=ctrl+comma=open_config
keybind=ctrl+shift+e=unbind
keybind=ctrl+shift+o=unbind
keybind=ctrl+shift+plus=increase_font_size:6
keybind=ctrl+shift+minus=set_font_size:17
keybind=ctrl+shift+r=reload_config
keybind=ctrl+shift+w=unbind
link-url=true
mouse-hide-while-typing = false
mouse-shift-capture=true
mouse-scroll-multiplier=1
theme=light:Catppuccin Latte,dark:Catppuccin Mocha
window-height=45
window-inherit-font-size=true
window-padding-color=extend
window-theme=ghostty
window-width=195
