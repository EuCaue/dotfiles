[user]
	name = EuCaue
	email = souzacaue@proton.me
[url  "git@github.com:"]
  insteadOf = "gh:"
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[init]
	defaultBranch = master
[commit]
  template = ~/dotfiles/dotconfig/git-template
[push]
  autoSetupRemote = true
  default = current
  followTags = true
[pull]
  default = current
	rebase = false
[rebase]
  autoStash = true
  missingCommitsCheck = true
[color]
	ui = true
[core]
  pager = delta
  whitespace = error
  preloadindex = true
[interactive]
  diffFilter = delta --color-only
[log]
  abbrevCommit = true
  graphColors = blue,yellow,cyan,magenta,green,red
[delta]
  navigate = true    # use n and N to move between diff sections
  line-numbers = true
  side-by-side = false
  tabs = 1
[branch]
  sort = -committerdate
[tag]
  sort = -taggerdate
[status]
  branch = true
  showStash = true
  showUntrackedFiles = all
[merge]
  tool = "nvimdiff3"
[diff]
  ; external = difft --display=inline
  renames = copies
  interHunkContext = 10
  context = 4
  colorMoved = default
[fetch]
  prune = true
[alias]
  a = add
  ap = add --patch 
  b = "branch --show-current"
  bs = "!git switch -c $1 2>/dev/null || git switch $1"
  bc = "!git checkout $1 2>/dev/null || git checkout -b $1"
  bd = "branch --delete --"
  bl = "branch -a"
  c = commit
  ca = commit --amend
  co = checkout
  d = diff
  f = fetch --prune
  ds = "diff --staged"
  ini = "init ."
  st = "stash -u "
  keep-only-branch = "!f() { git branch | grep -v $1 | xargs git branch -D; }; f"
  l = "log --oneline --graph --all --pretty=format:'%C(magenta)%h %C(white) %an %ar%C(auto) %D%n%s%n'"
  last-commit = "log -1 --stat"
  lo = "log --oneline --graph --all"
  ls = ls-files
  p = push
  pp = pull
  remove-file = "!f() { git filter-branch -f --index-filter \"git rm --cached --ignore-unmatch $1\" --prune-empty --tag-name-filter cat -- --all; }; f"
  mylog = "!f() { base=${1:-develop}; git log \"$base\"..HEAD --graph --pretty=format:'%C(magenta)%h %C(white)%an %ar%C(auto) %D%n%s%n'; }; f"
  baselog = "!f() { base=${1:-develop}; git log HEAD..\"$base\" --oneline; }; f"
  s = status -s
  undo = "reset --soft HEAD~1"
  unstage = "reset HEAD --"
  whatdiff = "log -p"
  clean-merged = "!f() { \
    branches=$(git branch --merged | grep -v '\\*\\|main\\|master\\|develop'); \
    if [ -z \"$branches\" ]; then \
      echo 'No branches to delete.'; \
    else \
      echo 'Branches to be deleted:'; \
      echo \"$branches\" | cat -n; \
      echo ''; \
      read -p 'Confirm? (y/N) ' confirm; \
      [ \"$confirm\" = 'y' ] && echo \"$branches\" | xargs git branch -d && echo 'Done!' || echo 'Cancelled.'; \
    fi; \
  }; f"
