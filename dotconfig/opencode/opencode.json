{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["cursor-acp", "@dietrichgebert/ponytail"],
  "autoupdate": true,
  "shell": "zsh",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"],
  },
  "lsp": true,
  "formatter": true,
  "permission": {
    "todowrite": "allow",
    "question": "allow",
  },
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false,
      },
    },
  },
  "provider": {
    "cursor-acp": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1",
      },
      "models": {
        "auto": {
          "name": "Auto",
          "cost": {
            "input": 1.25,
            "output": 6,
            "cache_read": 0.25,
            "cache_write": 1.25,
          },
        },
        "composer-1.5": {
          "name": "Composer 1.5",
          "cost": {
            "input": 3.5,
            "output": 17.5,
            "cache_read": 0.35,
            "cache_write": 3.5,
          },
        },
        "composer-1": {
          "name": "Composer 1",
        },
        "opus-4.6-thinking": {
          "name": "Claude 4.6 Opus (Thinking)",
        },
        "opus-4.6": {
          "name": "Claude 4.6 Opus",
        },
        "sonnet-4.6": {
          "name": "Claude 4.6 Sonnet",
        },
        "sonnet-4.6-thinking": {
          "name": "Claude 4.6 Sonnet (Thinking)",
        },
        "opus-4.5": {
          "name": "Claude 4.5 Opus",
        },
        "opus-4.5-thinking": {
          "name": "Claude 4.5 Opus (Thinking)",
        },
        "sonnet-4.5": {
          "name": "Claude 4.5 Sonnet",
        },
        "sonnet-4.5-thinking": {
          "name": "Claude 4.5 Sonnet (Thinking)",
        },
        "gpt-5.4-high": {
          "name": "GPT-5.4 High",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 2.5,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5,
              "cache_write": 5,
            },
          },
        },
        "gpt-5.4-medium": {
          "name": "GPT-5.4",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 2.5,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
